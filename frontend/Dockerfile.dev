# Base image can be overridden to pull from an internal Docker proxy.
ARG BASE_IMAGE=node:20-alpine

# Development Dockerfile for Next.js frontend with hot reload
FROM ${BASE_IMAGE}

RUN corepack enable

WORKDIR /app

# Optional internal npm registry (e.g. JFrog Artifactory). When unset, the
# official registry is used and behavior is unchanged.
ARG NPM_REGISTRY=
ARG NPM_AUTH_TOKEN=

# Copy package files
COPY package.json yarn.lock ./

# Install dependencies. When NPM_REGISTRY is set, point Yarn at it first.
RUN yarn config set nodeLinker node-modules && \
    if [ -n "$NPM_REGISTRY" ]; then \
      yarn config set npmRegistryServer "$NPM_REGISTRY" && \
      yarn config set unsafeHttpWhitelist --json "[\"$(echo "$NPM_REGISTRY" | sed -E 's|^https?://([^/:]+).*|\1|')\"]"; \
    fi && \
    if [ -n "$NPM_AUTH_TOKEN" ]; then yarn config set npmAuthToken "$NPM_AUTH_TOKEN"; fi && \
    yarn install

# Copy config files (these don't change often)
COPY next.config.js tsconfig.json postcss.config.js tailwind.config.js ./

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Default command for development
CMD ["yarn", "dev"]
